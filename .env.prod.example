# === OCEAN — Variables de entorno para producción ===
# Copia este archivo como .env y rellena los valores
#
# Generar JWT_SECRET:      openssl rand -hex 64
# Generar POSTGRES_PASSWORD: openssl rand -base64 32

# PostgreSQL
POSTGRES_USER=ocean
POSTGRES_PASSWORD=cambia-esta-contraseña-muy-larga
POSTGRES_DB=ocean_db

# Backend
JWT_SECRET=cambia-esto-por-una-cadena-larga-y-aleatoria-minimo-64-caracteres
CORS_ORIGIN=https://app.ocean-eeg.org

# Frontend — URL pública de la API (baked en el build de React)
# Debe ser accesible desde el navegador del usuario
# Con nginx en el mismo servidor: https://tudominio.com/api
# En local: http://localhost:4000
VITE_API_URL=https://app.ocean-eeg.org/api
