version: "3.9"

services:
  postgres:
    image: postgres:16-alpine
    container_name: ocean-postgres
    restart: unless-stopped
    environment:
      POSTGRES_USER: ${POSTGRES_USER:-ocean}
      POSTGRES_PASSWORD: ${POSTGRES_PASSWORD:-oceanpass}
      POSTGRES_DB: ${POSTGRES_DB:-ocean_db}
    volumes:
      - pgdata:/var/lib/postgresql/data
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U ${POSTGRES_USER:-ocean} -d ${POSTGRES_DB:-ocean_db}"]
      interval: 5s
      timeout: 5s
      retries: 5
    networks:
      - ocean

  backend:
    build:
      context: ./backend
      dockerfile: Dockerfile.prod
    container_name: ocean-backend
    restart: unless-stopped
    ports:
      - "4000:4000"
    environment:
      DATABASE_URL: postgresql://${POSTGRES_USER:-ocean}:${POSTGRES_PASSWORD:-oceanpass}@postgres:5432/${POSTGRES_DB:-ocean_db}
      JWT_SECRET: ${JWT_SECRET:?JWT_SECRET no está definido}
      PORT: 4000
      NODE_ENV: production
      STORAGE_TYPE: filesystem
      UPLOAD_DIR: /app/uploads/cases
      CORS_ORIGIN: ${CORS_ORIGIN:-*}
    volumes:
      - uploads:/app/uploads/cases
    depends_on:
      postgres:
        condition: service_healthy
    networks:
      - ocean

  frontend:
    build:
      context: ./frontend
      dockerfile: Dockerfile.prod
      args:
        VITE_API_URL: ${VITE_API_URL:-http://localhost:4000}
    container_name: ocean-frontend
    restart: unless-stopped
    ports:
      - "80:80"
    depends_on:
      - backend
    networks:
      - ocean

volumes:
  pgdata:
  uploads:

networks:
  ocean:
    driver: bridge
