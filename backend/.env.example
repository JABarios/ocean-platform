DATABASE_URL=file:./dev.db

# JWT — generar con: openssl rand -hex 64
# run-dev.sh genera uno automáticamente en instalaciones nuevas
JWT_SECRET=

# Custodia de claves EEG — DEBE ser distinto de JWT_SECRET en producción
KEY_CUSTODY_SECRET=

# Importación de galerías — directorio base permitido para datasets ya preparados
GALLERY_IMPORT_ROOT=

PORT=4000
NODE_ENV=development

# Almacenamiento: filesystem (default) o s3
STORAGE_TYPE=filesystem
UPLOAD_DIR=./uploads/cases

# S3 / MinIO (solo cuando STORAGE_TYPE=s3)
# S3_ENDPOINT=http://localhost:9000
# S3_BUCKET=ocean-cases
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# S3_REGION=us-east-1
