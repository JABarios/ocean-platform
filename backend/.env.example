# Base de datos
DATABASE_URL=file:./dev.db
# Para producción con PostgreSQL:
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# JWT — generar con: openssl rand -hex 64
JWT_SECRET=

# Servidor
PORT=4000
NODE_ENV=development

# Almacenamiento — "filesystem" (dev) o "s3" (prod)
STORAGE_TYPE=filesystem
UPLOAD_DIR=./uploads/cases

# S3 / MinIO (solo cuando STORAGE_TYPE=s3)
S3_ENDPOINT=
S3_BUCKET=ocean-cases
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=us-east-1
